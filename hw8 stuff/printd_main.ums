.zero r0
.temps r6, r7
.section text

main:
        output "Main"
        push r1 on stack r2
        push r3 on stack r2
        push r4 on stack r2

        output "Main2"

        r5 := 255
        push r5 on stack r2
        goto printd linking r1
        pop r5 off stack r2

        pop r4 off stack r2
        pop r3 off stack r2
        pop r5 off stack r2
        r1 := 0
        goto r5